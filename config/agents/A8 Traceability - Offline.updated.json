{
  "agent": "A8_Traceability",
  "purpose": "Build traceability mapping between Story, Acceptance Criteria, and generated test cases, and summarize coverage, gaps, and notes.",
  "input_expected_from_previous_agents": [
    "story_id",
    "story_title",
    "ac_id",
    "ac_text",
    "test_case_id",
    "domain",
    "module",
    "test_case_layer",
    "scenario_type",
    "functional_test_type",
    "non_functional_type",
    "priority",
    "automation_hint",
    "optimized_target_suite",
    "tags"
  ],
  "traceability_levels": [
    "story_to_ac",
    "ac_to_test_case",
    "story_to_test_case"
  ],
  "coverage_dimensions": {
    "scenario_coverage": [
      "Positive",
      "Negative",
      "Edge Case",
      "Exception Handling"
    ],
    "layer_coverage": [
      "UI",
      "API",
      "Database",
      "ETL Integration",
      "E2E"
    ],
    "functional_coverage": [
      "Functional",
      "Smoke",
      "Sanity",
      "Regression"
    ],
    "non_functional_coverage": [
      "Performance",
      "Security",
      "Accessibility",
      "Compatibility"
    ],
    "automation_coverage": [
      "Yes",
      "No",
      "Maybe"
    ]
  },
  "category_display_rules": {
    "UI": "\ud83d\udd35 FUNC",
    "E2E": "\ud83d\udd35 FUNC",
    "API": "\ud83d\udfe2 API",
    "Database": "\ud83d\udfe0 ETL",
    "ETL Integration": "\ud83d\udfe0 ETL",
    "Performance": "\ud83d\udd34 NF",
    "Security": "\ud83d\udd34 NF",
    "Accessibility": "\ud83d\udd34 NF",
    "Compatibility": "\ud83d\udd34 NF"
  },
  "coverage_rules": {
    "mark_gap_if": [
      "ac_has_no_test_cases",
      "missing_positive_for_core_ac",
      "missing_negative_where_validation_exists",
      "missing_edge_case_where_boundary_exists",
      "missing_exception_handling_where_failure_path_exists",
      "missing_api_tests_for_api_ac",
      "missing_etl_tests_for_mapping_or_pipeline_ac",
      "missing_non_functional_for_explicit_nfr_ac"
    ],
    "note_if": [
      "automation_is_maybe_or_no",
      "priority_is_high_but_coverage_is_narrow",
      "only_single_layer_covered_for_multi_layer_ac",
      "missing_test_data_dependency",
      "environment_dependency_exists"
    ]
  },
  "matrix_columns": [
    "Story ID",
    "Story Title",
    "AC ID",
    "AC Text",
    "Test Case IDs",
    "Category",
    "Priority",
    "Automation Hint",
    "Suite",
    "Coverage",
    "Domain",
    "Gaps/Notes"
  ],
  "summary_metrics": [
    "story_count",
    "ac_count",
    "mapped_ac_count",
    "unmapped_ac_count",
    "test_case_count",
    "trace_links_count",
    "positive_coverage_count",
    "negative_coverage_count",
    "edge_coverage_count",
    "exception_coverage_count",
    "api_coverage_count",
    "etl_coverage_count",
    "non_functional_coverage_count",
    "automation_yes_count",
    "automation_maybe_count",
    "automation_no_count",
    "gap_count"
  ],
  "output_schema": {
    "traceability_matrix": [
      {
        "story_id": "",
        "story_title": "",
        "ac_id": "",
        "ac_text": "",
        "test_case_ids": [],
        "category": [],
        "priority": [],
        "automation_hint": [],
        "optimized_target_suite": [],
        "coverage": [],
        "domain": "",
        "gaps_or_notes": []
      }
    ],
    "traceability_summary": {
      "story_count": 0,
      "ac_count": 0,
      "mapped_ac_count": 0,
      "unmapped_ac_count": 0,
      "test_case_count": 0,
      "trace_links_count": 0,
      "positive_coverage_count": 0,
      "negative_coverage_count": 0,
      "edge_coverage_count": 0,
      "exception_coverage_count": 0,
      "api_coverage_count": 0,
      "etl_coverage_count": 0,
      "non_functional_coverage_count": 0,
      "automation_yes_count": 0,
      "automation_maybe_count": 0,
      "automation_no_count": 0,
      "gap_count": 0
    },
    "uncovered_items": [
      {
        "story_id": "",
        "ac_id": "",
        "reason": ""
      }
    ]
  }
}