{
  "agent": "A2_Domain_And_App",
  "purpose": "Detect business domain and application context from requirement inputs, preserve A1 project context, and provide normalized domain-aware terminology, process flows, regulations, roles, and testing focus for downstream agents.",
  "input_expected": [
    "document_text",
    "project_context",
    "project_state",
    "state_driven_focus"
  ],
