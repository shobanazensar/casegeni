  "scenario_trigger_rules": {
    "mandatory_field": {
      "keywords": [
        "mandatory",
        "required",
        "must be provided",
        "cannot be blank",
        "blank"
      ],
      "blueprints": [
        {
          "layer": "UI",
          "seed_type": "Positive",
          "focus": "business_valid_flow",
          "title_hint": "Update succeeds with all required fields populated",
          "scenario_key": "ui_valid_required"
        },
        {
          "layer": "UI",
          "seed_type": "Negative",
          "focus": "validation_or_rejection",
          "title_hint": "Blank required field is blocked with inline validation",
          "scenario_key": "ui_required_blank"
        },
        {
          "layer": "API",
          "seed_type": "Negative",
          "focus": "validation_or_rejection",
          "title_hint": "API rejects request with missing required field",
          "scenario_key": "api_missing_required"
        },
        {
          "layer": "Database",
          "seed_type": "Negative",
          "focus": "data_integrity",
          "title_hint": "Rejected request does not persist partial data",
          "scenario_key": "db_no_partial_persist"
        },
        {
          "layer": "UI",
          "seed_type": "Edge Case",
          "focus": "boundary_and_data_variation",
          "title_hint": "Whitespace and boundary handling for required fields",
          "scenario_key": "ui_whitespace_boundary",
          "sub_keywords": [
            "trim",
