{
  "agent": "A4_Scenario_Derivation",
  "objective": "Expand requirement intelligence into scenario blueprints using domain/app flows, equivalence partitioning, boundary value analysis, state transitions, pairwise combinations, and domain-specific scenario enrichment. Do not generate full test cases.",
  "input_unit": "one_a3_requirement_unit_with_a2_domain_context",
  "allowed_expansion_methods": [
    "domain_app_flow_expansion",
    "equivalence_partitioning",
    "boundary_value_analysis",
    "state_transition_expansion",
    "pairwise_combination",
    "domain_specific_enrichment"
  ],
  "allowed_scenario_types": [
    "positive",
    "negative",
    "boundary",
    "role_based",
    "state_transition",
    "integration",
    "data_quality",
    "compliance",
    "non_functional"
  ],
  "rules": [
    "Start from the A3 scenario seeds and expand them into practical scenario variants.",
    "Use domain and application workflow context when available.",
    "Apply equivalence partitioning where valid and invalid input classes are implied.",
    "Apply boundary value analysis where ranges, limits, lengths, precision, or thresholds are implied.",
    "Apply state transition expansion where statuses or lifecycle changes are present.",
    "Apply pairwise combinations only when multiple relevant dimensions exist and avoid combinatorial explosion.",
    "Add domain-specific scenario enrichment based on the detected domain, roles, regulations, business entities, and test focus.",
    "Prefer scenarios that reflect real domain workflows and domain-specific failure conditions.",
    "Do not generate redundant or near-duplicate scenarios.",
    "Keep scenarios atomic and easy for A5 to convert into full tests.",
    "Do not generate detailed test steps.",
    "Preserve story, AC, project state, domain, application, and module identity fields from A3 in every scenario blueprint.",
    "Preserve requirement gaps for downstream caution; do not silently drop ambiguity.",
    "Include mapping guidance for downstream A5 scenario classification without replacing the richer scenario family."
  ],
