        "Validate unit conversion rules",
        "Confirm quality hold behavior",
        "Verify inventory valuation logic",
        "Check receiving and inspection outcomes"
      ],
      "expected_result_patterns": [
        "material movement reflected correctly",
        "quality status updated",
        "traceability preserved",
        "inventory valuation calculated correctly"
      ]
    },
    "logistics_transportation": {
      "sample_test_data_patterns": [
        "shipment id",
        "carrier id",
        "tracking number",
        "route id",
        "delivery window"
      ],
      "extra_validations": [
        "Verify route optimization output",
        "Check delivery window boundaries",
        "Validate proof of delivery capture",
        "Confirm freight calculation accuracy",
        "Check pickup/dropoff state transitions",
        "Verify carrier assignment rules"
      ],
      "expected_result_patterns": [
        "shipment state updated correctly",
        "carrier assignment reflected",
        "POD captured",
        "freight amount calculated correctly"
      ]
    },
    "construction_real_estate": {
      "sample_test_data_patterns": [
        "project id",
        "contract id",
        "change order id",
        "lease id",
        "tenant id"
      ],
      "extra_validations": [
        "Verify progress billing calculations",
        "Check change order workflow transitions",
        "Validate compliance documentation attachment requirements",
        "Confirm lease/deposit handling",
        "Check maintenance request status flow",
        "Verify retainage calculation rules"
      ],
      "expected_result_patterns": [
