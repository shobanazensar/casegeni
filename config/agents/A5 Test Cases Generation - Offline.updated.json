  "test_generation_templates": {
    "UI": [
      "Login or access application with the required role",
      "Navigate to the relevant module or screen",
      "Perform the business action using the specified input data",
      "Validate the UI response and business outcome"
    ],
    "API": [
      "Prepare endpoint, method, headers, and authentication",
      "Set request parameters or payload using test data",
      "Send the request",
      "Validate response status, body, headers, and business outcome"
    ],
    "Database": [
      "Prepare prerequisite data in source tables or dependent entities",
      "Execute the triggering action or query",
      "Validate stored data, field values, and constraints",
      "Verify reconciliation or persistence outcome"
    ],
    "ETL Integration": [
      "Prepare source data set with required variations",
      "Execute batch, pipeline, or triggering integration flow",
      "Validate transformation, mapping, and target load",
      "Verify reconciliation, reject handling, and downstream outcome"
    ],
    "E2E": [
      "Prepare end-to-end business preconditions",
      "Execute the workflow across involved modules or systems",
      "Validate intermediate state transitions and integrations",
      "Verify final business outcome in downstream system, notification, or report"
    ]
  },
  "domain_specific_generation": {
    "healthcare": {
      "sample_test_data_patterns": [
        "TEST_PATIENT_HIPAA",
        "ICD-10 code",
        "CPT code",
        "provider NPI",
        "claim id"
      ],
      "extra_validations": [
        "Verify ICD-10 diagnosis codes mapped correctly",
        "Confirm CPT procedure codes valid for date of service",
        "Check patient eligibility at time of service",
        "Validate NPI numbers for rendering/referring providers",
        "Ensure PHI not exposed in logs/response",
        "Confirm claim passes HIPAA-compatible format validation"
      ],
      "expected_result_patterns": [
        "clinical codes validated",
        "claim status updated correctly",
        "audit log captured",
        "PHI masked",
        "insurance verification outcome reflected"
      ]
    },
    "financial_services": {
      "sample_test_data_patterns": [
        "account id",
        "beneficiary account",
        "routing number",
        "SWIFT/BIC",
        "currency pair"
      ],
      "extra_validations": [
        "Verify exchange rate applied matches rate table",
        "Check rounding rules for applicable currencies",
        "Validate SWIFT/BIC or routing number format",
        "Confirm regulatory reporting triggered for threshold amounts",
        "Verify audit trail captures all changes",
        "Check fee calculation including flat and percentage components"
      ],
      "expected_result_patterns": [
        "amount transferred correctly",
        "balance updated correctly",
        "audit trail created",
        "regulatory checks triggered",
        "precision and rounding rules applied"
      ]
    },
    "ecommerce_retail": {
      "sample_test_data_patterns": [
        "SKU",
        "coupon code",
        "cart id",
        "order id",
        "shipping address"
      ],
      "extra_validations": [
        "Verify price and discount calculations",
        "Check tax by jurisdiction",
        "Validate inventory sync after order placement",
        "Confirm coupon or promotion eligibility logic",
        "Check refund amount and status updates",
        "Verify order fulfillment status propagation"
      ],
      "expected_result_patterns": [
        "order total calculated correctly",
        "inventory updated",
        "tax applied correctly",
        "refund processed correctly",
        "fulfillment status reflected"
      ]
    },
    "manufacturing_supply_chain": {
      "sample_test_data_patterns": [
        "BOM id",
        "work order id",
        "lot number",
        "serial number",
        "warehouse bin"
      ],
      "extra_validations": [
        "Verify BOM accuracy",
