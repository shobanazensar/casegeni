    "base_seed",
    "scenario_family",
    "a5_scenario_type_hint",
    "derived_from",
    "actor",
    "action",
    "business_object",
    "preconditions",
    "test_focus",
    "domain_test_focus",
    "input_variants",
    "expected_outcome",
    "compliance_tags",
    "requirement_gaps",
    "tags"
  ],
  "mandatory_classifications": {
    "domain": "required",
    "module": "required",
    "test_case_layer": [
      "UI",
      "API",
      "Database",
      "ETL Integration",
      "E2E"
    ],
    "scenario_type": [
