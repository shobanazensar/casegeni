  "automation_rules": {
    "default": "Yes",
    "output_field": "automation_hint_initial",
    "mark_no_if": [
      "exploratory",
      "one_time_validation",
      "manual_visual_check",
      "stakeholder_confirmation_required"
    ],
    "mark_maybe_if": [
      "complex_e2e",
      "external_dependency",
      "unstable_environment",
      "high_setup_cost",
      "partial_manual_verification"
    ]
  },
