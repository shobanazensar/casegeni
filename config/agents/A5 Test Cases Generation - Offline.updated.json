      "Sanity",
      "Regression"
    ],
    "non_functional_type": [
      "Performance",
      "Security",
      "Accessibility",
      "Compatibility"
    ],
    "automation_hint_initial": [
      "Yes",
      "No",
      "Maybe"
    ]
  },
